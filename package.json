{
  "name": "@tsxr1ck/contextkit",
  "version": "0.2.1",
  "type": "module",
  "description": "Scaffold concise Claude Code memory files for any repository",
  "bin": {
    "contextkit": "./src/cli/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "watch": "bun run src/cli/index.ts watch",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit",
    "lint": "bun x biome check .",
    "build": "bun build src/cli/index.ts --outdir dist --target bun"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/figlet": "^1.7.0",
    "@types/react": "^19.1.0"
  },
  "license": "MIT",
  "keywords": [
    "claude",
    "claude-code",
    "memory",
    "scaffolder",
    "context",
    "CLAUDE.md",
    "ai",
    "developer-tools",
    "tui",
    "watcher"
  ],
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "chokidar": "^4.0.0",
    "figlet": "^1.11.0",
    "ink": "^7.0.4",
    "ink-spinner": "^5.0.0",
    "picocolors": "^1.1.1",
    "react": "^19.1.0",
    "ts-morph": "^25.0.0",
    "zustand": "^5.0.0"
  }
}
