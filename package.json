{
  "name": "contextkit",
  "version": "0.1.0",
  "type": "module",
  "description": "Scaffold concise Claude Code memory files for any repository",
  "bin": {
    "contextkit": "./src/cli/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit",
    "lint": "bun x biome check .",
    "build": "bun build src/cli/index.ts --outdir dist --target bun"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "license": "MIT",
  "keywords": [
    "claude",
    "claude-code",
    "memory",
    "scaffolder",
    "context",
    "CLAUDE.md",
    "ai",
    "developer-tools"
  ],
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "picocolors": "^1.1.1"
  }
}
